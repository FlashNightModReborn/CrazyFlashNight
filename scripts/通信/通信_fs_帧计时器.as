 *   _root.её§и®Ўж—¶еҷЁ.жүӢеҠЁи®ҫзҪ®жҖ§иғҪзӯүзә§(0, 3);  // жҒўеӨҚйў„и®ҫз”»иҙЁпјҢдҝқжҠӨ3з§’
 */
_root.её§и®Ўж—¶еҷЁ.жүӢеҠЁи®ҫзҪ®жҖ§иғҪзӯүзә§ = function(зӣ®ж Үзӯүзә§:Number, дҝқжҢҒз§’ж•°:Number):Void {
    // еӣәеҢ–еҚ•и·Ҝеҫ„пјҡз”ұ PerformanceScheduler жҺҘз®ЎпјҲдҝқжҢҒAPIдёҚеҸҳпјү
    this.scheduler.setPerformanceLevel(зӣ®ж Үзӯүзә§, дҝқжҢҒз§’ж•°);
};

/**
 * йҷҚдҪҺжҖ§иғҪзӯүзә§пјҲйў„йҳІжҖ§йҷҚжЎЈпјү- зӣёеҜ№еүҚйҰҲ
 * еңЁеҪ“еүҚзӯүзә§еҹәзЎҖдёҠдёӢйҷҚNжЎЈпјҢйҖӮеҗҲдёҚзЎ®е®ҡеҪ“еүҚжЎЈдҪҚж—¶дҪҝз”Ё
 *
 * гҖҗжҺ§еҲ¶зҗҶи®әжіЁи§ЈгҖ‘
 *   иҝҷжҳҜгҖҢеўһйҮҸејҸеүҚйҰҲгҖҚпјҡО”u = +дёӢйҷҚжЎЈж•°
 *   зӣёжҜ”з»қеҜ№ејҸеүҚйҰҲпјҲжүӢеҠЁи®ҫзҪ®жҖ§иғҪзӯүзә§пјүпјҢеўһйҮҸејҸжӣҙзЁіеҒҘпјҡ
 *   вҖў еҰӮжһңеҪ“еүҚе·Із»ҸеңЁдҪҺз”»иҙЁпјҢдёҚдјҡй”ҷиҜҜең°жҸҗеҚҮеҲ°й«ҳз”»иҙЁ
 *   вҖў йҖӮеҗҲгҖҢжҲ‘зҹҘйҒ“иҰҒйҷҚпјҢдҪҶдёҚзЎ®е®ҡйҷҚеҲ°е“ӘгҖҚзҡ„еңәжҷҜ
 *
 *   жіЁж„Ҹпјҡ2жЎЈжЁЎеһӢдёӢеҸӘжңү tier 0/1пјҢйҷҚ1жЎЈеҚіеҲ°еә•гҖӮ
 *   еҗҢ tier еүҚйҰҲд»Қдјҡжү§иЎҢпјҲйҮҚе»ә hold + ејәеҲ¶ softU=1.0пјүгҖӮ
 *
 * @param дёӢйҷҚжЎЈж•° дёӢйҷҚзҡ„жЎЈдҪҚж•°йҮҸпјҢй»ҳи®Ө1жЎЈ
 * @param дҝқжҢҒз§’ж•° пјҲеҸҜйҖүпјүдҝқжҠӨж—¶й—ҙпјҲз§’пјүпјҢй»ҳи®Ө5з§’
 *
 * зӨәдҫӢпјҡ
 *   _root.её§и®Ўж—¶еҷЁ.йҷҚдҪҺжҖ§иғҪзӯүзә§(1);      // йҷҚ1жЎЈпјҢдҝқжҠӨ5з§’
 *   _root.её§и®Ўж—¶еҷЁ.йҷҚдҪҺжҖ§иғҪзӯүзә§(1, 10);  // йҷҚ1жЎЈпјҢдҝқжҠӨ10з§’
 */
_root.её§и®Ўж—¶еҷЁ.йҷҚдҪҺжҖ§иғҪзӯүзә§ = function(дёӢйҷҚжЎЈж•°:Number, дҝқжҢҒз§’ж•°:Number):Void {
    // еӣәеҢ–еҚ•и·Ҝеҫ„пјҡз”ұ PerformanceScheduler жҺҘз®ЎпјҲдҝқжҢҒAPIдёҚеҸҳпјү
    this.scheduler.decreaseLevel(дёӢйҷҚжЎЈж•°, дҝқжҢҒз§’ж•°);
};

/**
 * жҸҗеҚҮжҖ§иғҪзӯүзә§пјҲжҒўеӨҚжҖ§еҚҮжЎЈпјү- зӣёеҜ№еүҚйҰҲ
 * еңЁеҪ“еүҚзӯүзә§еҹәзЎҖдёҠжҸҗеҚҮNжЎЈпјҢз”ЁдәҺжҲҳж–—з»“жқҹеҗҺжҒўеӨҚз”»иҙЁ
 *
 * гҖҗжҺ§еҲ¶зҗҶи®әжіЁи§ЈгҖ‘
 *   иҝҷжҳҜгҖҢеўһйҮҸејҸеүҚйҰҲгҖҚпјҡО”u = -жҸҗеҚҮжЎЈж•°
 *   жіЁж„ҸпјҡжҸҗеҚҮз”»иҙЁеә”и°Ёж…ҺпјҢеӣ дёәеҸҜиғҪеҜјиҮҙ FPS дёӢйҷҚ
 *   е»әи®®дҝқжҢҒж—¶й—ҙи®ҫзҹӯдёҖдәӣпјҢи®©еҸҚйҰҲжҺ§еҲ¶еҝ«йҖҹжҺҘз®Ў
 *
 * @param жҸҗеҚҮжЎЈж•° жҸҗеҚҮзҡ„жЎЈдҪҚж•°йҮҸпјҢй»ҳи®Ө1жЎЈ
 * @param дҝқжҢҒз§’ж•° пјҲеҸҜйҖүпјүдҝқжҠӨж—¶й—ҙпјҲз§’пјүпјҢй»ҳи®Ө5з§’
 *
 * дҪҝз”ЁеңәжҷҜпјҡ
 *   - жҲҳж–—з»“жқҹеҗҺжҒўеӨҚз”»иҙЁ
 *   - дҪҺеҺӢеҠӣеңәжҷҜжҸҗеҚҮдҪ“йӘҢ
 *
 * зӨәдҫӢпјҡ
 *   _root.её§и®Ўж—¶еҷЁ.жҸҗеҚҮжҖ§иғҪзӯүзә§(1);     // еҚҮ1жЎЈпјҢдҝқжҠӨ5з§’
 *   _root.её§и®Ўж—¶еҷЁ.жҸҗеҚҮжҖ§иғҪзӯүзә§(1, 3);  // еҚҮ1жЎЈпјҢдҝқжҠӨ3з§’пјҲеҝ«йҖҹи®©еҸҚйҰҲжҺҘз®Ўпјү
 */
_root.её§и®Ўж—¶еҷЁ.жҸҗеҚҮжҖ§иғҪзӯүзә§ = function(жҸҗеҚҮжЎЈж•°:Number, дҝқжҢҒз§’ж•°:Number):Void {
    // еӣәеҢ–еҚ•и·Ҝеҫ„пјҡз”ұ PerformanceScheduler жҺҘз®ЎпјҲдҝқжҢҒAPIдёҚеҸҳпјү
    this.scheduler.increaseLevel(жҸҗеҚҮжЎЈж•°, дҝқжҢҒз§’ж•°);
};

// ===================================================================
// cleanupForRestart - жёёжҲҸйҮҚеҗҜеүҚзҡ„з»ҹдёҖжё…зҗҶе…ҘеҸЈ
// з”ЁдәҺ loadMovieNum(..., 0) йҮҚиҪҪдё» SWF еүҚжё…зҗҶжүҖжңүжҢҒд№…зҠ¶жҖҒ
// ===================================================================

/**
 * жё…зҗҶжүҖжңүжҢҒд№…зҠ¶жҖҒпјҢдёәжёёжҲҸйҮҚеҗҜеҒҡеҮҶеӨҮ
 *
 * и°ғз”Ёж—¶жңәпјҡ
 *   - иҝ”еӣһдё»иҸңеҚ•еүҚ
 *   - йҮҚж–°ејҖе§ӢжёёжҲҸеүҚ
 *   - д»»дҪ•йңҖиҰҒ loadMovieNum йҮҚиҪҪзҡ„еңәжҷҜеүҚ
 *
 * жё…зҗҶйЎәеәҸжҢүдҫқиө–е…ізі»жҺ’еҲ—пјҡ
 *   1. StageManager (жҢҒжңү WaveSpawner, StageEventHandler еј•з”Ё)
 *   2. StageEventHandler (жҢҒжңү gameworld.dispatcher еј•з”Ё)
 *   3. WaveSpawnWheel (жҢҒжңү WaveSpawner еј•з”Ё)
 *   4. SceneManager (жҢҒжңү gameworld MovieClip еј•з”Ё)
 *   5. WaveSpawner (жҢҒжңү StageManager, SceneManager, WaveSpawnWheel еј•з”Ё)
 *   6. Stage/Key зӣ‘еҗ¬еҷЁ
 *   7. EventBus
 *   8. йҹіж•ҲгҖҒkeyPollMCгҖҒ_global еҸҳйҮҸзӯү
 */
_root.cleanupForRestart = function():Void {
    _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] ејҖе§Ӣжё…зҗҶжҢҒд№…зҠ¶жҖҒ...");

    // -------------------------
    // 1. жё…зҗҶ StageManager (е…іеҚЎз®ЎзҗҶеҷЁ)
    // -------------------------
    if (StageManager.instance != null) {
        StageManager.instance.dispose();
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] StageManager disposed");
    }

    // -------------------------
    // 2. жё…зҗҶ StageEventHandler (е…іеҚЎдәӢд»¶еӨ„зҗҶеҷЁ)
    // -------------------------
    if (StageEventHandler.instance != null) {
        StageEventHandler.instance.dispose();
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] StageEventHandler disposed");
    }

    // -------------------------
    // 3. жё…зҗҶ WaveSpawnWheel (еҲ·жҖӘж—¶й—ҙиҪ®)
    // -------------------------
    if (WaveSpawnWheel.instance != null) {
        WaveSpawnWheel.instance.dispose();
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] WaveSpawnWheel disposed");
    }

    // -------------------------
    // 4. жё…зҗҶ SceneManager (еңәжҷҜз®ЎзҗҶеҷЁ)
    // -------------------------
    if (SceneManager.instance != null) {
        SceneManager.instance.dispose();
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] SceneManager disposed");
    }

    // -------------------------
    // 5. жё…зҗҶ WaveSpawner (еҲ·жҖӘеҷЁ)
    // -------------------------
    if (WaveSpawner.instance != null) {
        WaveSpawner.instance.dispose();
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] WaveSpawner disposed");
    }

    // -------------------------
    // 6. з§»йҷӨ Stage зӣ‘еҗ¬еҷЁ
    // -------------------------
    if (_root.её§и®Ўж—¶еҷЁ.stageWatcher != null) {
        Stage.removeListener(_root.её§и®Ўж—¶еҷЁ.stageWatcher);
        _root.её§и®Ўж—¶еҷЁ.stageWatcher = null;
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] Stage listener removed");
    }

    // -------------------------
    // 7. жё…зҗҶ EventBus
    // -------------------------
    if (EventBus.instance != null) {
        EventBus.instance.clear();
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] EventBus cleared");
    }

    // -------------------------
    // 8. еҒңжӯўжүҖжңүйҹіж•Ҳ
    // -------------------------
    stopAllSounds();
    _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] All sounds stopped");

    // -------------------------
    // 9. з§»йҷӨ keyPollMC (еҰӮжһңеӯҳеңЁ)
    // -------------------------
    if (_root.keyPollMC != null) {
        _root.keyPollMC.removeMovieClip();
        _root.keyPollMC = null;
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] keyPollMC removed");
    }

    // -------------------------
    // 10. жё…зҗҶ _global жҢҒд№…еҸҳйҮҸ
    // -------------------------
    if (_global.__HOLO_STRIPE__ != null) {
        // йҮҠж”ҫ BitmapData
        if (_global.__HOLO_STRIPE__.dispose != null) {
            _global.__HOLO_STRIPE__.dispose();
        }
        _global.__HOLO_STRIPE__ = null;
        _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] _global.__HOLO_STRIPE__ released");
    }

    // -------------------------
    // 11. жё…зҗҶ TargetCacheManager
    // -------------------------
    TargetCacheManager.clear();
    _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] TargetCacheManager cleared");

    // -------------------------
    // 11.5 жё…зҗҶ HitNumberBatchProcessor йҳҹеҲ— + FrameBroadcaster ж•°жҚ®ж§Ҫ
    // -------------------------
    HitNumberBatchProcessor.clear();
    FrameBroadcaster.reset();
    _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] HitNumberBatchProcessor + FrameBroadcaster cleared");

    // -------------------------
    // 12. жё…зҗҶ CooldownWheel е’Ң UnitUpdateWheel
    // -------------------------
    if (_root.её§и®Ўж—¶еҷЁ.cooldownWheel != null) {
        _root.её§и®Ўж—¶еҷЁ.cooldownWheel.clear();
    }
    if (_root.её§и®Ўж—¶еҷЁ.unitUpdateWheel != null) {
        _root.её§и®Ўж—¶еҷЁ.unitUpdateWheel.clear();
    }

    // -------------------------
    // 13. жё…зҗҶ TaskManager е’Ң ScheduleTimer
    // -------------------------
    if (_root.её§и®Ўж—¶еҷЁ.taskManager != null) {
        _root.её§и®Ўж—¶еҷЁ.taskManager.clear();
    }
    if (_root.её§и®Ўж—¶еҷЁ.ScheduleTimer != null) {
        _root.её§и®Ўж—¶еҷЁ.ScheduleTimer.clear();
    }

    _root.еҸ‘еёғж¶ҲжҒҜ("[cleanupForRestart] жё…зҗҶе®ҢжҲҗпјҢеҸҜд»Ҙе®үе…ЁйҮҚиҪҪ");
};
