        catName = ["arith","branch","access","call","string","convert","math","native","scope","array","gc"][ci];
        label = ["ARITH / COMPARE / BITWISE","BRANCH / CONTROL / LOGIC","ACCESS / MEMBER / ARRAY / CHAIN","CALL / NEW / CLOSURE / ARGUMENTS","STRING","CONVERT / TYPE / TYPEOF / CAST","MATH / NATIVES / BIT-HACKS","NATIVE BRIDGE (C++ glue cost)","SCOPE / MISC / UNDEFINED / TRY / EVAL","ARRAY METHODS","GC HEAVY"][ci];
