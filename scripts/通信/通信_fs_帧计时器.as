/**
 * е°Ҷе·Ізј–иҜ‘зҡ„ DFA ж•°жҚ®йҖҡиҝҮ D еүҚзјҖеҸ‘йҖҒеҲ° Launcher V8гҖӮ
 * еҸҜиғҪеңЁд»ҘдёӢж—¶жңәиў«и°ғз”Ёпјҡ
 * 1. жһ„е»әжҗ“жӢӣжЁЎз»„() е®ҢжҲҗеҗҺпјҲеҰӮжһң socket е·ІиҝһжҺҘпјү
 * 2. frameUpdate дёӯжЈҖжөӢеҲ° dfaBuilt дҪҶжңӘеҸ‘йҖҒпјҲsocket е»¶иҝҹиҝһжҺҘзҡ„жғ…еҶөпјү
 */
_root.её§и®Ўж—¶еҷЁ.еҸ‘йҖҒDFAж•°жҚ®еҲ°Launcher = function():Void {
    if (this.dfaSentToLauncher || !this.dfaBuilt) return;
    var sm:Object = _root.server;
    if (sm == undefined || !sm.isSocketConnected) return;

    var moduleIds:Array = ["barehand", "lightWeapon", "heavyWeapon"];
    var moduleNums:Array = ["0", "1", "2"];
    for (var mi:Number = 0; mi < moduleIds.length; mi++) {
        var mod:Object = this.commandModules[moduleIds[mi]];
        if (mod != undefined && mod.registry != undefined) {
            sm.sendSocketMessage("D" + moduleNums[mi] + "\x01" + mod.registry.serializeForLauncher());
        }
    }
    this.dfaSentToLauncher = true;
};

/**
 * ж №жҚ®еҚ•дҪҚзҡ„ е…өеҷЁеҠЁдҪңзұ»еһӢ жҺЁж–ӯеҜ№еә”зҡ„жҗ“жӢӣжЁЎз»„
 * @param unit еҚ•дҪҚеҜ№иұЎ
 * @return жЁЎз»„еҗҚ: "barehand" | "lightWeapon" | "heavyWeapon"
 */
_root.её§и®Ўж—¶еҷЁ.жҺЁж–ӯеҠЁдҪңжЁЎз»„ = function(unit:Object):String {
    var state:String = unit.ж”»еҮ»жЁЎејҸ;

    // з©әжүӢжЁЎејҸ вҶ’ barehandпјҲжңҖеёёи§Ғи·Ҝеҫ„пјҢжңҖе…ҲеҲӨж–ӯе№¶з«ӢеҚіиҝ”еӣһпјү
    if (state == "з©әжүӢ") {
        return "barehand";
    }

    // йқһз©әжүӢж—¶жүҚи®Ўз®—жҠҖиғҪзҠ¶жҖҒ
    var isSkillState:Boolean = (state == "жҠҖиғҪ" || state == "жҲҳжҠҖ");

    // жӢізұ»жҠҖиғҪ/жҲҳжҠҖ вҶ’ barehand
    if (isSkillState && HeroUtil.isFistSkill(unit.жҠҖиғҪеҗҚ)) {
        return "barehand";
    }

    // е…өеҷЁжЁЎејҸпјҢжҲ–йқһжӢіжҠҖиғҪ/жҲҳжҠҖ вҶ’ ж №жҚ®е…өеҷЁеҠЁдҪңзұ»еһӢиҪ»йҮҚеҲ’еҲҶ
    if (state == "е…өеҷЁ" || isSkillState) {
        var actionType:String = unit.е…өеҷЁеҠЁдҪңзұ»еһӢ;
        if (actionType == "й•ҝжҹ„" || actionType == "й•ҝжһӘ" ||
            actionType == "й•ҝжЈҚ" || actionType == "зӢӮйҮҺ" ||
            actionType == "йҮҚж–©" || actionType == "й•°еҲҖ") {
            return "heavyWeapon";
        }
        return "lightWeapon";
    }

};

