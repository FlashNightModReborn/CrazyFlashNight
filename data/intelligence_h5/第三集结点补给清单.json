{
  "schemaVersion": 1,
  "itemName": "第三集结点补给清单",
  "skin": "report",
  "pages": [
    {
      "pageKey": "1_1",
      "blocks": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "（一张标准的物资清单，被贴在箱盖内侧）"
            }
          ]
        },
        {
          "type": "heading",
          "level": 2,
          "content": [
            {
              "type": "strong",
              "content": [
                {
                  "type": "text",
                  "text": "【补给箱 01 - 弹药/医疗】"
                }
              ]
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "状态："
            },
            {
              "type": "colorToken",
              "token": "danger",
              "content": [
                {
                  "type": "text",
                  "text": "封条已破坏"
                }
              ]
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "strong",
              "content": [
                {
                  "type": "text",
                  "text": "清单明细："
                }
              ]
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "突击步枪通用弹药 x 15组"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "12号霰弹弹药 x 10组"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "手枪通用弹药 x 20组"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "普通HP药剂 x 15"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "普通MP药剂 x 10"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "—— 后勤科"
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_2",
      "blocks": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "（清单下方用铅笔匆忙写下的留言，字迹清秀但笔锋锐利）"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "运输途中遭遇尸潮，车辆损毁。"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "无法固守，全员弃车突围。"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "丧尸从地底钻出。金属钻头破土，尸体随后涌出。"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "情报属实，地下数量不明。"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "丧尸不取死物，但须防盗贼。"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "开箱取弹药突围，清单数量已不准。"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "已呼叫支援。"
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "text",
              "text": "记得清点弹药，莫浪费。"
            }
          ]
        }
      ]
    }
  ]
}
