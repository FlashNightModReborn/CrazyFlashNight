                "type": "colorToken",
                "token": "material-basic",
                "content": [
                  {
                    "type": "text",
                    "text": "军用帆布"
                  }
                ]
              },
              {
                "type": "text",
                "text": "1块，"
              },
              {
                "type": "colorToken",
                "token": "info",
                "content": [
                  {
                    "type": "text",
                    "text": "碳纤维布料"
                  }
                ]
              },
              {
                "type": "text",
                "text": "1份。"
              }
            ],
            [
              {
                "type": "text",
                "text": "其中作战服需要1瓶"
