//----------------------------------------------------
// 刀光系统（进一步优化版）
//----------------------------------------------------
_root.刀光系统 = {};

//----------------------------------------------------
// 初始化函数：定义样式、历史轨迹记录以及最大历史帧数
//----------------------------------------------------
_root.刀光系统.初始化 = function () {
    // 定义各种刀光样式（颜色、线条宽度及透明度等）
    this.刀光样式 = {
        预设: {
            颜色: 0xFFFFFF,
            线条颜色: 0xFFFFFF,
            线条宽度: 2,
            填充透明度: 100,
            线条透明度: 100
        },
        白色蓝框: {
            颜色: 0xFFFFFF,
            线条颜色: 0x4FB6FF,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        红色透明: {
            颜色: 0xFF6666,
            线条颜色: 0xFF6666,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        蓝色魅影: {
            颜色: 0x4DE6FF,
            线条颜色: 0x4FB6FF,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        蓝色幽灵: {
            颜色: 0x74EBFF,
            线条颜色: 0x74EBFF,
            线条宽度: 2,
            填充透明度: 25,
            线条透明度: 25
        }
    };

    // 记录每个发射者下，每个刀口（通常为两个边界点）的历史运动轨迹
    this.轨迹记录 = {};
    // 最大历史帧数（可根据需求进一步调小来提高性能）
    this.最大帧数 = 5; // *可调整*
};

_root.刀光系统.初始化();

//-----------------------------------------------------------------------
// 对外接口：绘制刀本体及其刀光
//-----------------------------------------------------------------------
_root.刀光系统.绘制刀及其刀光 = function(影片剪辑:MovieClip, 刀光样式名:String, 参数:Object) {
    _root.残影系统.绘制元件(影片剪辑.man.刀, 参数);
    this.绑定并绘制刀光(影片剪辑, 刀光样式名);
};

_root.刀光系统.绘制人物及其刀光 = function(影片剪辑:MovieClip, 刀光样式名:String, 参数:Object) {
    _root.残影系统.绘制元件(影片剪辑, 参数);
    this.绑定并绘制刀光(影片剪辑, 刀光样式名);
};

//-----------------------------------------------------------------------
// 绑定并绘制刀光：采集刀口位置数据并调用核心更新绘制函数
//-----------------------------------------------------------------------
_root.刀光系统.绑定并绘制刀光 = function(影片剪辑:MovieClip, 刀光样式名:String) {
    var 刀口集合 = [];
    var 装扮 = 影片剪辑.man.刀.刀.装扮;
    for (var i = 1; i <= 5; i++) {
        var 当前刀口 = 装扮["刀口位置" + i];
        if (当前刀口 && 当前刀口._x != undefined) {
            var 点集 = _root.影片剪辑至游戏世界点集(当前刀口);
            刀口集合.push({ edge1: 点集[0], edge2: 点集[1] });
        }
    }
    if (刀口集合.length > 0) {
        // 以影片剪辑名称作为发射者标识，确保轨迹数据独立
        this.更新和绘制刀光(影片剪辑._name, 刀口集合, 刀光样式名);
    }
};

//-----------------------------------------------------------------------
// 针对独立刀对象的绘制（逻辑同上）
//-----------------------------------------------------------------------
_root.刀光系统.刀引用绘制刀光 = function(自机:MovieClip, 影片剪辑:MovieClip, 刀光样式名:String) {
    var 刀口集合 = [];
    for (var i = 1; i <= 5; i++) {
        var 当前刀口 = 影片剪辑["刀口位置" + i];
        if (当前刀口 && 当前刀口._x != undefined) {
            var myPoints = _root.影片剪辑至游戏世界点集(当前刀口);
            刀口集合.push({ edge1: myPoints[0], edge2: myPoints[1] });
        }
    }
    if (刀口集合.length > 0) {
        this.更新和绘制刀光(自机, 刀口集合, 刀光样式名);
    }
};

//-----------------------------------------------------------------------
// 核心更新绘制函数：更新历史轨迹采样并分段绘制四边形
//-----------------------------------------------------------------------
_root.刀光系统.更新和绘制刀光 = function(发射者, 刀口数组, 刀光样式名) {
    var 当前帧 = _root.帧计时器.当前帧数;
    
    // 如果该发射者无记录，则初始化每个刀口的轨迹数据
    if (!this.轨迹记录[发射者]) {
        this.轨迹记录[发射者] = { _lastFrame: 当前帧 };
        for (var i = 0; i < 刀口数组.length; i++) {
            this.轨迹记录[发射者][i] = {
                edge1: [ 刀口数组[i].edge1 ],
                edge2: [ 刀口数组[i].edge2 ]
            };
        }
        return;
    }
    
    var 记录 = this.轨迹记录[发射者];
    // 如果中断超过 30 帧，则重置轨迹数据以避免过多旧数据
    if (当前帧 - 记录._lastFrame > 30) {
        for (var i = 0; i < 刀口数组.length; i++){
            记录[i] = {
                edge1: [ 刀口数组[i].edge1 ],
                edge2: [ 刀口数组[i].edge2 ]
            };
        }
        记录._lastFrame = 当前帧;
        return;
    }
    
    // 更新每个刀口的历史轨迹
    for (var i = 0; i < 刀口数组.length; i++){
        if (!记录[i]) {
            记录[i] = { edge1: [], edge2: [] };
        }
        记录[i].edge1.push(刀口数组[i].edge1);
        记录[i].edge2.push(刀口数组[i].edge2);
        if (记录[i].edge1.length > this.最大帧数) { 记录[i].edge1.shift(); }
        if (记录[i].edge2.length > this.最大帧数) { 记录[i].edge2.shift(); }
    }

    // 针对每个刀口绘制拖尾四边形
    for (var i = 0; i < 刀口数组.length; i++){
        var traj = 记录[i];
        if (traj.edge1.length < 2 || traj.edge2.length < 2) continue;
        
        // 平滑更新：为降低计算频率，每隔 3 帧进行一次平滑处理
        if (当前帧 % 3 == 0) {
            this.简单平滑(traj.edge1);
            this.简单平滑(traj.edge2);
        }
        
        // 将相邻两帧构成一个四边形，采用非线性透明度衰减
        for (var j = 0; j < traj.edge1.length - 1; j++) {
            var ptE1A = traj.edge1[j];
            var ptE1B = traj.edge1[j+1];
            var ptE2A = traj.edge2[j];
            var ptE2B = traj.edge2[j+1];

            // 利用指数衰减计算透明度
            var alphaFactor = 100 * Math.pow(0.7, j);
            
            var quadPoints = [ 
                { x: ptE1A.x, y: ptE1A.y },
                { x: ptE1B.x, y: ptE1B.y },
                { x: ptE2B.x, y: ptE2B.y },
                { x: ptE2A.x, y: ptE2A.y }
            ];
            
            this.绘制于残影系统(quadPoints, 刀光样式名, alphaFactor);
        }
    }
    记录._lastFrame = 当前帧;
};

//-----------------------------------------------------------------------
// 简单平滑函数：对轨迹点做移动平均，减少抖动
// 添加了边界检查，确保 (i-1) 与 (i+1) 存在
//-----------------------------------------------------------------------
_root.刀光系统.简单平滑 = function(点数组:Array) {
    if (点数组.length < 3) return;
    // 遍历中间点，确保 i-1 与 i+1 合法
    for (var i = 1; i < 点数组.length - 1; i++) {
        // 安全检查：确保前后点存在（一般情况下满足）
        if (i - 1 >= 0 && i + 1 < 点数组.length) {
            点数组[i].x = (点数组[i-1].x + 点数组[i].x + 点数组[i+1].x) / 3;
            点数组[i].y = (点数组[i-1].y + 点数组[i].y + 点数组[i+1].y) / 3;
        }
    }
};

//-----------------------------------------------------------------------
// 根据样式及透明度调用残影系统绘制四边形
//-----------------------------------------------------------------------
_root.刀光系统.绘制于残影系统 = function(刀口点集, 刀光样式名, 透明度) {
    var 样式 = this.刀光样式[刀光样式名] || this.刀光样式['预设'];
    var 最终填充透明度 = 样式.填充透明度 * (透明度 / 100);
    var 最终线条透明度 = 样式.线条透明度 * (透明度 / 100);
    _root.残影系统.绘制形状(
        刀口点集,   // 多边形点集
        样式.颜色, // 填充颜色
        样式.线条颜色, // 线条颜色
        样式.线条宽度, // 线条宽度
        最终填充透明度, // 填充透明度
        最终线条透明度  // 线条透明度
    );
};

/**
 * 清理刀光系统内存（支持手动调用+自动阈值判断）
 * @param forceCleanAll 是否强制清理所有记录（默认false，按阈值清理）
 * @param maxInactiveFrames 判定为"闲置"的最大帧数（默认300帧=10秒@30FPS）
 */
_root.刀光系统.清理内存 = function(forceCleanAll:Boolean, maxInactiveFrames:Number) {
    if (forceCleanAll == undefined) forceCleanAll = false;
    if (maxInactiveFrames == undefined) maxInactiveFrames = 300;
    
    var 当前帧 = _root.帧计时器.当前帧数;
    var 清理数量 = 0;
    
    for (var 发射者 in this.轨迹记录) {
        var 记录 = this.轨迹记录[发射者];
        // 强制清理 或 超过最大闲置帧数
        if (forceCleanAll || (当前帧 - 记录._lastFrame > maxInactiveFrames)) {
            delete this.轨迹记录[发射者];
            清理数量++;
        }
    }
    
    trace("[刀光系统] 已清理 " + 清理数量 + " 个闲置发射者轨迹");
    return 清理数量; // 返回清理数量便于监控
};