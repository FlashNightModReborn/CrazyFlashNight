    <!-- ========== 磁暴科技 (Tesla) ========== -->
    <!-- 基础版: single模式, 低压放电原型——电弧不稳定、分叉少、色泽偏暗 -->
    <bullet>
        <name>磁暴射线</name>
        <attribute>
            <hitMark>电击弹坑</hitMark>
            <rayConfig>
                <rayLength>700</rayLength>
                <vfxStyle>tesla</vfxStyle>
                <vfxPreset>ra2_tesla</vfxPreset>
                <primaryColor>0x66CCCC</primaryColor>
                <secondaryColor>0xCCDDDD</secondaryColor>
                <thickness>1.5</thickness>
                <branchCount>2</branchCount>
                <branchProbability>0.3</branchProbability>
                <segmentLength>25</segmentLength>
                <jitter>12</jitter>
                <visualDuration>4</visualDuration>
                <fadeOutDuration>2</fadeOutDuration>
            </rayConfig>
        </attribute>
    </bullet>
    <!-- 强化版: 纯chain专精, 高弹跳次数补偿功能单一, 闪电在密集敌群中大量弹跳 -->
    <bullet>
        <name>磁暴射线-强化</name>
        <attribute>
            <hitMark>电击弹坑</hitMark>
            <pierceLimit>10</pierceLimit>
            <rayConfig>
                <rayLength>900</rayLength>
                <rayMode>chain</rayMode>
                <vfxStyle>tesla</vfxStyle>
                <vfxPreset>ra2_tesla</vfxPreset>
                <chainDelay>2</chainDelay>
                <damageFalloff>0.8</damageFalloff>
                <chainRadius>200</chainRadius>
                <primaryColor>0x00FFFF</primaryColor>
                <secondaryColor>0xFFFFFF</secondaryColor>
                <thickness>2</thickness>
                <branchCount>4</branchCount>
                <branchProbability>0.5</branchProbability>
                <segmentLength>25</segmentLength>
                <jitter>18</jitter>
                <visualDuration>5</visualDuration>
                <fadeOutDuration>3</fadeOutDuration>
            </rayConfig>
        </attribute>
    </bullet>

