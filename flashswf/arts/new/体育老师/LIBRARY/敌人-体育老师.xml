                    <script><![CDATA[onClipEvent (enterFrame) {
	if (this._currentframe == 1)
	{
		var 攻击对象 = _root.gameworld[_parent.攻击目标];
		var 距离X = Math.abs(_parent._x - 攻击对象._x);
		var 距离Z = Math.abs(_parent.Z轴坐标 - 攻击对象.Z轴坐标);
		if (this.hitTest(攻击对象.area) && 距离Z <= _parent.y轴攻击范围)
		{
			play();
			if (_parent.宠物属性.弹射弧光斩 && 距离X > 250 && random(_parent.攻击欲望 * 2) == 0)
			{
				_parent.状态改变("弹射弧光斩");

			}
			if (random(_parent.攻击欲望) == 0)
			{
				if (距离X > 350)
				{
					_parent.近战招式 = "a1";
					_parent.状态改变("近战");

				}
				else
				{
					_parent.近战招式 = "a0";
					_parent.状态改变("近战");
				}

			}
		}else if(_parent.宠物属性.弹射弧光斩 && 距离X < 500 && 距离Z <= 90){
			if ( random(_parent.攻击欲望 * 5) == 0)
			{
				_parent.状态改变("弹射弧光斩");

			}
		}
	}
