# dotnet publish 输出目录（build.ps1 跑 Step 4 时重新生成）
launcher/publish/
launcher/publish-test/

# Rust cargo build intermediates (launcher/native/sol_parser)
# Cargo.lock IS tracked: sol_parser ships as an application cdylib, not a
# library crate, so pinning transitive deps is required for reproducible /
# offline builds.
launcher/native/sol_parser/target/

# amf0-help: AMF0 Reference 求助/上游 issue 复现包 (源码与样本入库, 生成物不入库)
amf0-help/sol_parser/target/
amf0-help/sol_parser/flwriter_probe.sol
amf0-help/**/*.probe.json
/amf0-help.zip

# WebView2 runtime cache (machine-specific)
launcher/webview2_userdata/
launcher/webview2_overlay_userdata/
weboverlay_debug.log

# Launcher runtime logs
logs/

# Legacy user prefs path (runtime now migrates to %LOCALAPPDATA%)
launcher_user_prefs.json

# Save shadow backups (player-specific, not source)
saves/*.json
saves/*.json.tmp
# 玩家本地修复备份与 audit log（C1b/C2-α 自动写入，含真实存档数据，不入库）
saves/.repair-backups/
# launcher 版本 gate marker（机器本地状态）
saves/.launcher-version-marker.json
saves/.launcher-version-marker.json.tmp

# cf7-save-repair TS 工具产物（dist 由 tsc 生成；coverage 由 vitest 生成）
tools/cf7-save-repair/dist/
tools/cf7-save-repair/coverage/
# 同源 dict-build 工具
tools/cf7-save-repair-dict-build/dist/
tools/cf7-save-repair-dict-build/coverage/

# Python bytecode cache (任何 tools/ 下跑过 .py 都会生成；解释器自动重建)
**/__pycache__/

# AI sim 生成结果（每次 run 重写）
tools/mercenary-ai-sim/results/
tools/combat-movement-sim/results/

# 调试探针/临时 DOM 快照等 ad-hoc 产物, 禁止入库
/tmp/
/tmp-*
/tmp-*.html
/tmp-*.json
/tmp-*.txt
/tmp_ffdec_*/

# Native cursor image-generation review sheets (generated, not source)
launcher/web/assets/cursor/native/review/
*.tombstone

# .fla zip 编辑 (strip_orphan_linkage.py) 的备份
*.fla.bak

# linkage_scanner 缓存输出 (跑一次 scan_linkage.py 即重新生成)
tools/linkage_scanner/_last_output.txt
