//----------------------------------------------------
// 刀光系统（优化版）
//----------------------------------------------------
_root.刀光系统 = {};

//----------------------------------------------------
// 初始化函数：定义样式、历史轨迹记录以及最大历史帧数
//----------------------------------------------------
_root.刀光系统.初始化 = function () {
    // 定义各种刀光样式（颜色、线条宽度及透明度等）
    this.刀光样式 = {
        预设: {
            颜色: 0xFFFFFF,
            线条颜色: 0xFFFFFF,
            线条宽度: 2,
            填充透明度: 100,
            线条透明度: 100
        },
        白色蓝框: {
            颜色: 0xFFFFFF,
            线条颜色: 0x4FB6FF,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        红色透明: {
            颜色: 0xFF6666,
            线条颜色: 0xFF6666,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        蓝色魅影: {
            颜色: 0x4DE6FF,
            线条颜色: 0x4FB6FF,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        蓝色幽灵: {
            颜色: 0x74EBFF,
            线条颜色: 0x74EBFF,
            线条宽度: 2,
            填充透明度: 25,
            线条透明度: 25
        }
    };

    // 记录每个发射者下，每个刀口（通常为两个边界点）的历史运动轨迹
    this.轨迹记录 = {};
    // 最大历史帧数（可根据需求再调小来提高性能）
    this.最大帧数 = 5;  // *可调整*
};

_root.刀光系统.初始化();

//-----------------------------------------------------------------------
// 对外接口：绘制刀本体及其刀光
//-----------------------------------------------------------------------
_root.刀光系统.绘制刀及其刀光 = function(影片剪辑:MovieClip, 刀光样式名:String, 参数:Object) {
    // 绘制刀本体
    _root.残影系统.绘制元件(影片剪辑.man.刀, 参数);
    // 绘制刀光
    this.绑定并绘制刀光(影片剪辑, 刀光样式名);
};

_root.刀光系统.绘制人物及其刀光 = function(影片剪辑:MovieClip, 刀光样式名:String, 参数:Object) {
    // 绘制人物
    _root.残影系统.绘制元件(影片剪辑, 参数);
    // 绘制刀光
    this.绑定并绘制刀光(影片剪辑, 刀光样式名);
};

//-----------------------------------------------------------------------
// 绑定并绘制刀光：采集刀口位置数据并调用核心更新绘制函数
//-----------------------------------------------------------------------
_root.刀光系统.绑定并绘制刀光 = function(影片剪辑:MovieClip, 刀光样式名:String) {
    var 刀口集合 = [];
    var 装扮 = 影片剪辑.man.刀.刀.装扮;
    for (var i = 1; i <= 5; i++) {
        var 当前刀口 = 装扮["刀口位置" + i];
        if (当前刀口 && 当前刀口._x != undefined) {
            var 点集 = _root.影片剪辑至游戏世界点集(当前刀口);
            刀口集合.push({ edge1: 点集[0], edge2: 点集[1] });
        }
    }
    if (刀口集合.length > 0) {
        // 以影片剪辑名称作为发射者标识，确保轨迹数据独立
        this.更新和绘制刀光(影片剪辑._name, 刀口集合, 刀光样式名);
    }
};

//-----------------------------------------------------------------------
// 针对独立刀对象的绘制（逻辑同上）
//-----------------------------------------------------------------------
_root.刀光系统.刀引用绘制刀光 = function(自机:MovieClip, 影片剪辑:MovieClip, 刀光样式名:String) {
    var 刀口集合 = [];
    for (var i = 1; i <= 5; i++) {
        var 当前刀口 = 影片剪辑["刀口位置" + i];
        if (当前刀口 && 当前刀口._x != undefined) {
            var myPoints = _root.影片剪辑至游戏世界点集(当前刀口);
            刀口集合.push({ edge1: myPoints[0], edge2: myPoints[1] });
        }
    }
    if (刀口集合.length > 0) {
        this.更新和绘制刀光(自机, 刀口集合, 刀光样式名);
    }
};

//-----------------------------------------------------------------------
// 核心更新绘制函数：更新历史轨迹采样并绘制多个四边形
//-----------------------------------------------------------------------
_root.刀光系统.更新和绘制刀光 = function(发射者, 刀口数组, 刀光样式名) {
    var 当前帧 = _root.帧计时器.当前帧数;
    
    // 如果该发射者无记录，则初始化
    if (!this.轨迹记录[发射者]) {
        this.轨迹记录[发射者] = { _lastFrame: 当前帧 };
        for (var i = 0; i < 刀口数组.length; i++) {
            this.轨迹记录[发射者][i] = {
                edge1: [ 刀口数组[i].edge1 ],
                edge2: [ 刀口数组[i].edge2 ]
            };
        }
        return;
    }
    
    var 记录 = this.轨迹记录[发射者];
    // 若距离上次更新超过 30 帧，则重置，防止拖尾数据过多
    if (当前帧 - 记录._lastFrame > 30) {
        for (var i = 0; i < 刀口数组.length; i++){
            记录[i] = {
                edge1: [ 刀口数组[i].edge1 ],
                edge2: [ 刀口数组[i].edge2 ]
            };
        }
        记录._lastFrame = 当前帧;
        return;
    }
    // 更新每个刀口的轨迹
    for (var i = 0; i < 刀口数组.length; i++){
        if (!记录[i]) {
            记录[i] = { edge1: [], edge2: [] };
        }
        记录[i].edge1.push(刀口数组[i].edge1);
        记录[i].edge2.push(刀口数组[i].edge2);
        // 超过最大帧数就丢弃最旧的
        if (记录[i].edge1.length > this.最大帧数) { 记录[i].edge1.shift(); }
        if (记录[i].edge2.length > this.最大帧数) { 记录[i].edge2.shift(); }
    }

    // 对每个刀口进行绘制
    for (var i = 0; i < 刀口数组.length; i++){
        var traj = 记录[i];
        // 轨迹数不足 2 无法生成四边形
        if (traj.edge1.length < 2 || traj.edge2.length < 2) continue;
        
        // （1）先做简单的“移动平均”平滑，减少抖动 & 降低插值量
        this.简单平滑(traj.edge1);
        this.简单平滑(traj.edge2);
        
        // （2）相邻两帧组成一个四边形进行绘制
        //     第 j 段： e1[j], e1[j+1], e2[j+1], e2[j]
        for (var j = 0; j < traj.edge1.length - 1; j++) {
            var ptE1A = traj.edge1[j];
            var ptE1B = traj.edge1[j+1];
            var ptE2A = traj.edge2[j];
            var ptE2B = traj.edge2[j+1];

            // 根据段索引让旧段更透明（这里用线性递减做演示，可自行改进）
            // *可调整*：根据 j 或 (traj.length - j) 来确定衰减
            var alphaFactor = 100 - (j / (traj.edge1.length - 1)) * 80;
            
            // 构造四边形点集
            var quadPoints = [ 
                { x: ptE1A.x, y: ptE1A.y },
                { x: ptE1B.x, y: ptE1B.y },
                { x: ptE2B.x, y: ptE2B.y },
                { x: ptE2A.x, y: ptE2A.y }
            ];
            
            // 调用绘制
            this.绘制于残影系统(quadPoints, 刀光样式名, alphaFactor);
        }
    }
    记录._lastFrame = 当前帧;
};

//-----------------------------------------------------------------------
// 简单平滑算法：对轨迹点做移动平均，减少抖动
//-----------------------------------------------------------------------
_root.刀光系统.简单平滑 = function(点数组:Array) {
    if (点数组.length < 3) return; // 只有2个点则无需平滑
    
    // *可调整*：遍历除首尾之外的中间点，并将其位置设置为(前+本+后)/3
    for (var i = 1; i < 点数组.length - 1; i++) {
        点数组[i].x = (点数组[i-1].x + 点数组[i].x + 点数组[i+1].x) / 3;
        点数组[i].y = (点数组[i-1].y + 点数组[i].y + 点数组[i+1].y) / 3;
    }
};

//-----------------------------------------------------------------------
// 根据样式及透明度调用残影系统绘制四边形
//-----------------------------------------------------------------------
_root.刀光系统.绘制于残影系统 = function(刀口点集, 刀光样式名, 透明度) {
    var 样式 = this.刀光样式[刀光样式名] || this.刀光样式['预设'];
    // 填充和线条透明度统一乘以传入的“动态透明度”因子
    var 最终填充透明度 = 样式.填充透明度 * (透明度 / 100);
    var 最终线条透明度 = 样式.线条透明度 * (透明度 / 100);
    
    // 使用残影系统绘制形状
    // 这里四边形直接作为多边形点集传入
    _root.残影系统.绘制形状(
        刀口点集,                 // 多边形点集
        样式.颜色,               // 填充颜色
        样式.线条颜色,           // 线条颜色
        样式.线条宽度,           // 线条宽度
        最终填充透明度,           // 填充透明度
        最终线条透明度            // 线条透明度
    );
};
