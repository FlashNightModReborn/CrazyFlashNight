{
  "name": "cf7-balance-tool",
  "version": "0.1.0",
  "private": true,
  "description": "CF7 balance management tool workspace",
  "type": "module",
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b packages/core packages/xml-io packages/cli --pretty false && npm run typecheck --workspace @cf7-balance-tool/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "field-scan": "tsx packages/cli/src/index.ts project fields",
    "project-scan": "tsx packages/cli/src/index.ts project scan",
    "dev:web": "npm run dev:renderer --workspace @cf7-balance-tool/web",
    "dev:electron": "npm run dev:electron --workspace @cf7-balance-tool/web"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}