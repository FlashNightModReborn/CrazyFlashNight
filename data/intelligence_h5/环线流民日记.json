              "type": "strong",
              "content": [
                {
                  "type": "text",
                  "text": "【批注：12月21号毕业 哈哈哈狗日的正好被学校踹出来】"
                }
              ]
            }
          ]
        },
        {
          "type": "table",
          "columns": [
            "字段",
            "内容"
          ],
          "rows": [
            [
              [
                {
                  "type": "text",
