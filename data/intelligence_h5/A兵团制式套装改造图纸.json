                "type": "text",
                "text": "喷涂灰蓝色迷彩。"
              }
            ],
            [
              {
                "type": "text",
                "text": "裤子和皮靴各需要1块"
              },
              {
                "type": "colorToken",
                "token": "material-basic",
                "content": [
                  {
                    "type": "text",
                    "text": "可塑式钢板"
                  }
                ]
              },
              {
                "type": "text",
                "text": "制作护膝和防撞头。"
              }
            ],
            [
              {
                "type": "text",
                "text": "翻新项链需要少量"
              },
              {
                "type": "colorToken",
                "token": "material-mid",
                "content": [
                  {
                    "type": "text",
                    "text": "高强度合金"
                  }
                ]
              },
              {
                "type": "text",
                "text": "与"
              },
              {
                "type": "colorToken",
                "token": "material-mid",
                "content": [
                  {
                    "type": "text",
                    "text": "高耐力橡胶"
                  }
                ]
              },
              {
                "type": "text",
                "text": "。"
