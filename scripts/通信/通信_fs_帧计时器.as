_root.её§и®Ўж—¶еҷЁ.й”®зӣҳиҫ“е…ҘжҺ§еҲ¶зӣ®ж Ү = function()
{
    var жҺ§еҲ¶еҜ№иұЎ = TargetCacheManager.findHero()
    if(!жҺ§еҲ¶еҜ№иұЎ) return;

    if(_root.жҡӮеҒң){
        // жё…з©әжүҖжңүзҠ¶жҖҒ
