{
  "schemaVersion": 1,
  "itemName": "γ-ECHO病理摘要",
  "skin": "terminal",
  "pages": [
    {
      "pageKey": "1_1",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "【机密】γ-ECHO感染病理摘要"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "文件编号：PATH-2012-1221-07"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "撰写人："
                    }
                  ]
                },
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "damageText",
                      "kind": "edited",
                      "text": "[已编辑]"
                    }
                  ]
                },
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": " 主任研究员"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "审批：外部接口人（统合部门联络）"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "一、感染分期"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "第一期：潜伏期（D-14至D-7）"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 生理指标无明显异常"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 血清γ-ECHO抗体滴度≤1:80"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 可能出现轻微记忆混乱、手部震颤"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 此阶段感染者对信号无响应"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_2",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "第二期：活化期（D-7至D-1）"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 血清变黑，黏稠度上升"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 皮肤灰化，眼眶凹陷"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 喉部出现异常振动（疑似次声波发生器官萌芽）"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 抗体滴度急剧上升至1:320以上"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "第三期：增生期（D日至D+7）"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 骨髓异常活跃，成骨细胞向体表迁移"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 皮下出现骨质结节，分布于四肢关节及躯干"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 体型开始膨胀，肌肉纤维被骨化组织取代"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 攻击性显著上升，痛觉丧失"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_3",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "第四期：骨刺化（D+7至D+14）"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 骨质突破表皮，形成外露骨刺"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 骨刺主要分布：肘部、肩胛、脊椎、膝关节"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 骨刺硬度超过正常骨骼3-5倍"
                }
              ]
            },
            {
              "kind": "system",
              "content": [
                {
                  "type": "text",
                  "text": "- 神经系统完全被γ-ECHO信号接管"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 攻击性极强，具备超常力量与速度"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "第五期：衰竭期（D+14至D+28）"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 骨质过度增生导致内脏压迫、血管阻塞"
                }
              ]
            },
            {
              "kind": "system",
              "content": [
                {
                  "type": "text",
                  "text": "- 代谢系统崩溃，组织开始坏死"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 骨刺脆化，战斗效能急剧下降"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- "
                },
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "预期存活周期：2-4周"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 最终因结构性崩溃而死亡（非外力击杀）"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_4",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "设计意图备注："
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "γ-ECHO本质上是一种"
                },
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "短命的可控生物兵器"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "高攻击性以牺牲寿命为代价，符合一次性消耗品的战术定位。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "缺陷：清理成本高，无法长期部署。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "二、转化机制"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "γ-ECHO载体本身具备生物学必然性，感染后将不可避免地启动转化进程。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "信号（Signal）的作用是"
                },
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "催化剂/遥控开关"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "，而非转化的必要条件。"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_5",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "自然病程（无信号激活）："
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 转化周期：14-21天（自临床症状显现起计算，即活化期开始）"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 特征：缓慢、痛苦、意识保留至晚期"
                }
              ]
            },
            {
              "kind": "system",
              "content": [
                {
                  "type": "text",
                  "text": "- 宿主在转化过程中保持部分自我认知，直至神经系统被完全接管"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 最终形态不稳定，战斗效能较低"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "激活病程（信号触发）："
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 形态武器化：0.1-2秒（瞬间完成骨刺化、体型膨胀）"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 母体能力成熟：约2小时（次声波发生器官完全发育，获得感染扩散能力）"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 特征：无痛、意识即刻丧失、直接进入战斗形态"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 最终形态稳定，攻击性极强，可被信号遥控"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_6",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "级联反应（两种病程共有）："
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "1. 骨髓细胞异常增殖"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "2. 成骨细胞向体表迁移"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "3. 钙质在皮下异常沉积"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "4. 骨质穿透表皮形成外骨骼"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "注："
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "增生与骨刺化是同一进程的不同阶段。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "早期干预（增生期前）可通过信号屏蔽延缓转化，但无法逆转。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "进入骨刺化阶段后，体型将持续膨胀直至宿主结构崩溃。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_7",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "三、处置建议"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 增生期感染者：隔离观察，尝试信号屏蔽"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 骨刺化感染者："
                },
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "立即焚烧处理"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "（无Protocol-12式再生复活能力，但可发生死后骨刺增生）"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "警告："
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "确认尸体完全静止后方可处理——骨刺残留可能刺穿处置人员"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "警告："
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "死后骨刺化不可逆，即使自杀个体仍会完成转化，存在二次处置风险"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 骨刺化个体具备母体潜力，感染半径可达500米"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "- 禁止近距离接触，禁止活体研究"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_8",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "注："
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "本摘要仅涉及γ-ECHO（Protocol-7）相关病理。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "θ-HIVE强化型（Protocol-9）及Σ-ITE永生型（Protocol-12）病理参见各自独立档案。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "三种载体在外部试点中同步投放，形成对照实验。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "警告："
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "Protocol-12受试者禁止在确认死亡前火化处理，观察期不少于72小时。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "四、合作方备注"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "外部试点（水厂）的样本采集工作按计划推进。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "投放剂量已根据最新数据调整。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "二期管网投放效率已验证，三期建议采用封闭空间扩散（参见内部通讯#1220-A）。"
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "text",
                  "text": "本文件阅后即焚。违者按《紧急状态法》第7条处理。"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "pageKey": "1_9",
      "blocks": [
        {
          "type": "terminalLog",
          "title": "γ-ECHO病理摘要",
          "entries": [
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "【附录 - 重要观测发现】"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
                {
                  "type": "strong",
                  "content": [
                    {
                      "type": "text",
                      "text": "γ-ECHO / Σ-ITE 交叉感染现象："
                    }
                  ]
                }
              ]
            },
            {
              "kind": "text",
              "content": [
