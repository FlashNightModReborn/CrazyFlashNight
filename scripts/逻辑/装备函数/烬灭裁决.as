//烬灭裁决实装需求

//!!!!!!基础形态为长柄模式，现在游戏内基础形态为双刀模式了，弄反了！
//长柄模式与双刀模式下面板与属性会有差异，如果可以请读取长柄形态与双刀形态相应的xml文件面板，让它们在相应的形态拥有正确的数值。

//长柄模式：
//普攻：使用长柄模组攻击
//战技：回旋裂地
//武器属性：本体伤害为普通物理伤害
//切换成双刀的动画：things0内的"长柄变双刀"动画
//特效详细要求：
//长柄攻击一段特效：血痕爪杀，在雾人整合特效文件内，霰值1，热属性，子弹伤害120，z轴范围60
//长柄攻击二段特效：圣爆，在雾人整合特效文件内，霰值3，热属性，子弹伤害90，z轴范围120
//长柄攻击三段特效：圣爆，在雾人整合特效文件内，霰值3，热属性，子弹伤害90，z轴范围120
//长柄攻击四段特效：圣刺，在雾人整合特效文件内，霰值3，热属性，子弹伤害120，z轴范围120
//长柄攻击五段特效：血箭，在雾人整合特效文件内，霰值5，热属性，子弹伤害200，z轴范围60


//双刀模式：
//普攻：使用双刀模组攻击
//战技：深冲利刺
//武器属性：本体伤害为普通物理伤害
//切换成长柄的动画：things0内的"双刀变长柄"动画，
//双刀攻击一段特效：地面喷发，在雾人整合特效文件内，霰值3，热属性，子弹伤害90，z轴范围120
//双刀攻击二段特效：烈焰火花，在雾人整合特效文件内，霰值3，热属性，子弹伤害90，z轴范围120
//双刀攻击三段特效：黄金集气，在雾人整合特效文件内，霰值3，热属性，子弹伤害60，z轴范围120
//双刀攻击四段特效：圣刺，在雾人整合特效文件内，霰值1，热属性，子弹伤害200，z轴范围60


// =======================================================
//  烬灭裁决 · 装备生命周期函数（双形态变形武器）
// =======================================================
//  核心机制：运行时切换 刀_装扮 + 副刀 _visible + 战技容器刚体防打断
//  双 item 共存（"烬灭裁决"长柄 / "烬灭裁决双刀"双刀），wv.双刀形态 独立持久化
//  变形动画走战技路径；末帧回调执行形态切换；被打断零副作用
// =======================================================

_root.装备生命周期函数.烬灭裁决初始化 = function(ref, param)
{
    var unit = ref.自机;
    var wv = unit[ref.装备类型].value;

    // param.默认长柄 来自 initParam，长柄 item="true"、双刀 item="false"
    var 默认长柄态 = (param.默认长柄 == "true" || param.默认长柄 === true);
    var 长柄态 = _root.装备生命周期函数.读取持久值(wv, "长柄形态", 默认长柄态);

    // edge-trigger 初始化：种成当前键态，避免过图/复活/重装备时玩家本来按着键被误判为新按下
    ref.上次变形键按下 = _root.按键输入检测(unit, _root.武器变形键) ? true : false;

    // 完成变形回调（挂 unit 供战技容器末帧调用；闭包引用 ref）
    unit.烬灭裁决_完成变形 = function():Void {
        var 目标双刀 = (this.技能名 == "长柄变双刀");
        _root.装备生命周期函数.烬灭裁决_应用形态(ref, 目标双刀);
    };

    // 应用持久化形态（覆盖 item 初始 dressup/actiontype/bladeCount）
    _root.装备生命周期函数.烬灭裁决_应用形态(ref, 双刀态);
};

_root.装备生命周期函数.烬灭裁决周期 = function(ref, param)
{
    _root.装备生命周期函数.移除异常周期函数(ref);
    var unit = ref.自机;

    // 手工 edge-trigger：上升沿触发一次；按住不放战技结束后不会再次触发
    var 按住 = _root.按键输入检测(unit, _root.武器变形键) ? true : false;
    var 上升沿 = 按住 && !ref.上次变形键按下;
    ref.上次变形键按下 = 按住;

    if (上升沿 && _root.兵器使用检测(unit) && unit.状态 !== "战技") {
        _root.装备生命周期函数.烬灭裁决_请求变形(ref);
    }
    // 段位特效由武器 MC 自带的 onClipEvent(enterFrame) 直接调 _root.刀口触发特效.xxx
    // 周期函数不涉及特效分发
};

_root.装备生命周期函数.烬灭裁决_请求变形 = function(ref)
{
    var unit = ref.自机;
    var wv = unit[ref.装备类型].value;
    var 技能名 = (wv.双刀形态 === true) ? "双刀变长柄" : "长柄变双刀";
    // 走战技路由绕过 HP/MP 门控；unit.状态改变("战技") + attachMovie("战技容器-" + 技能名)
    _root.战技路由.战技标签跳转_旧(unit, 技能名);
};

_root.装备生命周期函数.烬灭裁决_应用形态 = function(ref, 目标双刀:Boolean)
{
    var unit = ref.自机;
    if (目标双刀) {
        unit.刀_装扮 = "刀-烬灭裁决主剑";
        unit.兵器动作类型 = "双刀";
        unit.刀_刀口数 = 3;
        if (unit.刀属性) unit.刀属性.bladeCount = 3;
        // hp/mp 必须为 String —— 装载主动战技 内部调 .indexOf
        unit.装载主动战技({skillname:"深冲利刺", cd:8000, hp:"0", mp:"80"}, "兵器");
    } else {
        unit.刀_装扮 = "刀-烬灭裁决长柄";
        unit.兵器动作类型 = "长柄";
        unit.刀_刀口数 = 5;
        if (unit.刀属性) unit.刀属性.bladeCount = 5;
        unit.装载主动战技({skillname:"回旋裂地", cd:7000, hp:"0", mp:"50"}, "兵器");
    }
    unit[ref.装备类型].value.双刀形态 = 目标双刀;  // 持久化到当前 item 实例的 value
    _root.装备引用配置.刷新所有装扮(unit);          // 重挂 刀_引用（首例运行时刀切换）
    if (unit.刀2_引用) unit.刀2_引用._visible = 目标双刀;  // 副刀可见性
    if (ref.是否为主角) {                            // 标记挂在 ref 上，不是 unit 上
        _root.玩家信息界面.玩家必要信息界面.战技栏.战技栏图标刷新();
    }
};

_root.装备生命周期函数.烬灭裁决初始化 = function (reflector:Object, paramObj:Object) {
    paramObj.position = paramObj.position || "刀口位置2";
    paramObj.func = paramObj.func || "_root.刀口触发特效.血痕爪杀";
    if(!paramObj.states) {
        paramObj.states = {};
        paramObj.states["兵器攻击"] = true;
    }
    _root.装备生命周期函数.通用特效刀口初始化(reflector, paramObj);
};