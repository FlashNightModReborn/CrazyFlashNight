<?xml version="1.0" encoding="UTF-8"?>
<trailStyles>
    <!-- ============================================================
         P1 几何增强字段说明：
           leadOffset  前缘切向前冲（hd 比例），正值 = 冲击感
           lagOffset   后缘切向拖曳（hd 比例），负值 = 拖尾感
           outerScale  外边缘(刀口侧)缩放，>1 更宽
           innerScale  内边缘(刀柄侧)缩放，<1 更窄 = 更锐利
           tailFade    尾部 alpha 衰减 0-1，0 = 无衰减
         所有 P1 字段可选，缺省时自动 backfill 默认值（零效果）。
         ============================================================ -->

    <!-- ═══════ 基础 ═══════ -->
    <style name="预设">
        <color>0xFFFFFF</color>
        <lineColor>0xFFFFFF</lineColor>
        <lineWidth>2</lineWidth>
        <fillOpacity>100</fillOpacity>
        <lineOpacity>100</lineOpacity>
        <leadOffset>0.04</leadOffset>
        <tailFade>0.15</tailFade>
    </style>

