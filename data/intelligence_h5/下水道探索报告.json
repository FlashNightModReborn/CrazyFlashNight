            {
              "type": "strong",
              "content": [
                {
                  "type": "colorToken",
                  "token": "danger",
                  "content": [
                    {
                      "type": "text",
                      "text": "务必速战速决。"
                    }
                  ]
                }
              ]
            },
            {
              "type": "text",
              "text": "\n"
            },
            {
              "type": "strong",
              "content": [
                {
                  "type": "colorToken",
                  "token": "danger",
                  "content": [
                    {
                      "type": "text",
                      "text": "战术指导："
