                <damageFalloff>1.0</damageFalloff>
                <!-- 带宽射线：屏幕-Y 半宽 = Z轴攻击范围 * 系数 * 0.5（本武器 Z轴攻击范围=42 → 半宽 = 21*系数）。
                     仅放宽屏幕-Y 命中以打矮碰撞箱敌（不碰深度门）。
                     真机日志标定：枪口常在矮鼠碰撞箱上方，最坏需半宽≈56px（系数≈2.7）才够到地面鼠；
                     故取系数 3（半宽 63，留余量）。手感按需调：偏小漏矮敌、偏大光束过高会扫到无关高空。 -->
                <rayWidthFactor>3</rayWidthFactor>
            </rayConfig>
        </attribute>
    </bullet>

    <!-- ========== 联弹「模板 × 单元体」双层配置 ==========
         模板声明联弹前缀的弹壳派生规则（casingMap：单元体材质→弹壳名）与属性覆盖；
         单元体在自身 <bullet> 条目上用 <chainUnit><material>…</material></chainUnit> 声明参与派生。
         加载期由 ChainBulletConfigResolver 交叉合并：显式 "模板-单元体" 条目始终优先，派生仅补缺。
         横向系=霰弹枪式齐射（穿刺上限特判为 2，仅替换单元体已声明的键）；纵向系=机枪式扫射。 -->
    <chainTemplate>
        <prefix>横向联弹</prefix>
        <shell>
            <xOffset>60</xOffset>
            <yOffset>0</yOffset>
            <simulationMethod>标准</simulationMethod>
            <casingMap>
                <entry><material>能量</material><casing>能量霰弹弹壳</casing></entry>
                <entry><material>加强</material><casing>加强霰弹弹壳</casing></entry>
                <entry><material>普通</material><casing>霰弹弹壳</casing></entry>
            </casingMap>
        </shell>
        <attributeOverride>
            <pierceLimit>2</pierceLimit>
