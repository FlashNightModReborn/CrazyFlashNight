{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arena-calibration.case-manifest.v1",
  "type": "object",
  "required": ["schema", "batchId", "arenaMode", "cases"],
  "properties": {
    "schema": { "const": "arena-calibration.case-manifest.v1" },
    "batchId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "createdAt": { "type": "string" },
    "buildCommit": { "type": "string" },
    "planner": { "type": "object" },
    "arenaMode": { "const": "calibration" },
    "repeat": { "type": "integer", "minimum": 1 },
    "timeoutFrames": { "type": "integer", "minimum": 1 },
    "blueBench": { "type": ["object", "null"] },
    "manifestHash": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["caseId", "blueRoster", "redRoster"],
        "properties": {
          "caseId": { "type": "string", "minLength": 1 },
          "caseHash": { "type": "string" },
          "blueRoster": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/rosterEntry" }
          },
          "redRoster": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/rosterEntry" }
          },
          "repeat": { "type": "integer", "minimum": 1 },
          "timeoutFrames": { "type": "integer", "minimum": 1 },
          "tags": { "type": "array", "items": { "type": "string" } },
          "plannerReason": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "rosterEntry": {
      "type": "object",
      "required": ["type", "level"],
      "properties": {
        "type": { "type": "string", "pattern": "^兵种[0-9]+$" },
        "level": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
