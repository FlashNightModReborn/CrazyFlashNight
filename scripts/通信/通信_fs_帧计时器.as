        жҺ§еҲ¶еҜ№иұЎ.дёҠиЎҢ = false;
        жҺ§еҲ¶еҜ№иұЎ.дёӢиЎҢ = false;
        жҺ§еҲ¶еҜ№иұЎ.еҠЁдҪңA = false;
        жҺ§еҲ¶еҜ№иұЎ.еҠЁдҪңB = false;
        жҺ§еҲ¶еҜ№иұЎ.еҠЁдҪңC = false;
        жҺ§еҲ¶еҜ№иұЎ.ејәеҲ¶еҘ”и·‘ = false;
        // жҡӮеҒңж—¶йҮҚзҪ®жҗ“жӢӣзҠ¶жҖҒ
        жҺ§еҲ¶еҜ№иұЎ.commandId = 0;
        жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣID = 0;
        жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣеҗҚ = "";
    }else{
        // дҪҝз”ЁдҪҚжҺ©з ҒеӯҳеӮЁжҢүй”®зҠ¶жҖҒ
        var mask:Number =
            (Key.isDown(жҺ§еҲ¶еҜ№иұЎ.е·Ұй”®) ? 1 : 0) |
            (Key.isDown(жҺ§еҲ¶еҜ№иұЎ.еҸій”®) ? 2 : 0) |
            (Key.isDown(жҺ§еҲ¶еҜ№иұЎ.дёҠй”®) ? 4 : 0) |
            (Key.isDown(жҺ§еҲ¶еҜ№иұЎ.дёӢй”®) ? 8 : 0) |
            (Key.isDown(жҺ§еҲ¶еҜ№иұЎ.Aй”®) ? 16 : 0) |
            (Key.isDown(жҺ§еҲ¶еҜ№иұЎ.Bй”®) ? 32 : 0) |
            (Key.isDown(жҺ§еҲ¶еҜ№иұЎ.Cй”®) ? 64 : 0) |
            (Key.isDown(_root.еҘ”и·‘й”®) ? 128 : 0); 

        // и§Јз ҒдҪҚжҺ©з Ғжӣҙж–°жҺ§еҲ¶еҜ№иұЎзҠ¶жҖҒ
        жҺ§еҲ¶еҜ№иұЎ.е·ҰиЎҢ = (mask & 1) != 0;
        жҺ§еҲ¶еҜ№иұЎ.еҸіиЎҢ = (mask & 2) != 0;
        жҺ§еҲ¶еҜ№иұЎ.дёҠиЎҢ = (mask & 4) != 0;
        жҺ§еҲ¶еҜ№иұЎ.дёӢиЎҢ = (mask & 8) != 0;
        жҺ§еҲ¶еҜ№иұЎ.еҠЁдҪңA = (mask & 16) != 0;
        жҺ§еҲ¶еҜ№иұЎ.еҠЁдҪңB = (mask & 32) != 0;
        жҺ§еҲ¶еҜ№иұЎ.еҠЁдҪңC = (mask & 64) != 0;
        // Shift еҘ”и·‘ дёҺ еҸҢеҮ»ж–№еҗ‘еҘ”и·‘ еҗҲе№¶еҲӨе®ҡ
        // - actionsPressedпјҡжҢүдёӢд»»дёҖ A/B/C еҲҷдёҚе…Ғи®ёиҝӣе…ҘеҘ”и·‘
        // - shiftRunпјҡжҢүдҪҸвҖңеҘ”и·‘й”®вҖқпјҲй»ҳи®Ө Shiftпјүж—¶и§ҰеҸ‘
        // - doubleRunпјҡUI еұӮйҖҡиҝҮ KeyManager и®ўйҳ…еҸҢеҮ»е·ҰеҸій”®еҗҺи®ҫзҪ®зҡ„ж–№еҗ‘ж„Ҹеӣҫ
        //              ctrl.doubleTapRunDirection = -1пјҲе·Ұпјү/ 1пјҲеҸіпјүпјҢжқҫејҖж–№еҗ‘й”®иҮӘеҠЁжё…йӣ¶
        var actionsPressed:Boolean = (mask & (16 | 32 | 64)) != 0;
        var shiftRun:Boolean = !actionsPressed && ((mask & 128) != 0);

        var doubleRun:Boolean = false;
        var dir:Number = жҺ§еҲ¶еҜ№иұЎ.doubleTapRunDirection;
        if (dir) {  // dir дёә null/undefined/0 ж—¶йғҪдёә false
            var leftPressed:Boolean = (mask & 1) != 0;
            var rightPressed:Boolean = (mask & 2) != 0;
            doubleRun = !actionsPressed && ((dir < 0 && leftPressed) || (dir > 0 && rightPressed));
            // иӢҘж°ҙе№іж–№еҗ‘еқҮжңӘжҢүдёӢпјҢеҲҷжё…йҷӨеҸҢеҮ»еҘ”и·‘ж–№еҗ‘
            if (!leftPressed && !rightPressed) {
                жҺ§еҲ¶еҜ№иұЎ.doubleTapRunDirection = 0;
            }
        }

        жҺ§еҲ¶еҜ№иұЎ.ејәеҲ¶еҘ”и·‘ = shiftRun || doubleRun;

        // === \x04 ж•°жҚ®еҸ‘йҖҒпјҡmask + жңқеҗ‘ + жЁЎз»„ + еҸҢеҮ»ж–№еҗ‘ вҶ’ Launcher V8 ===
        var жЁЎз»„еҗҚ:String = this.жҺЁж–ӯеҠЁдҪңжЁЎз»„(жҺ§еҲ¶еҜ№иұЎ);
        var facingBit:Number = (жҺ§еҲ¶еҜ№иұЎ.ж–№еҗ‘ == "еҸі") ? 1 : 0;
        var moduleId:Number = (жЁЎз»„еҗҚ == "barehand") ? 0 : ((жЁЎз»„еҗҚ == "heavyWeapon") ? 2 : 1);
        var dtDir:Number = жҺ§еҲ¶еҜ№иұЎ.doubleTapRunDirection;
        if (dtDir == undefined) dtDir = 0;
        FrameBroadcaster.setInputPayload(mask + "|" + facingBit + "|" + moduleId + "|" + dtDir);

        // === жҗ“жӢӣзј“еҶІпјҲиҫ“е…ҘжәҗпјҡLauncher K еүҚзјҖ cmdIdпјҢжӣҝд»Јжң¬ең° DFAпјү===
        var frame:Number = this.еҪ“еүҚеё§ж•°;
        var launcherCmdId:Number = FrameBroadcaster.getCmdId();

        // жЁЎз»„еҲҮжҚўж—¶жё…з©әзј“еҶІ
        if (жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣжЁЎз»„ != жЁЎз»„еҗҚ) {
            жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІID = 0;
            жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІеҗҚ = "";
            жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІе·Іж¶Ҳиҙ№ = true;
        }
        жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣжЁЎз»„ = жЁЎз»„еҗҚ;

        // Launcher DFA е‘Ҫдёӯж—¶еҶҷе…Ҙзј“еҶІпјҲеҗҢж—¶зј“еӯҳеҗҚеӯ—пјҢеӣ дёәдёӢдёҖеё§ K дјҡжё…з©ә _cmdNameпјү
        if (launcherCmdId != 0) {
            жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІID = launcherCmdId;
            жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІеҗҚ = FrameBroadcaster.getCmdName();
            жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІеё§ = frame;
            жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІе·Іж¶Ҳиҙ№ = false;
        }

        // ж №жҚ®е®Ҫе®№её§ж•°еҶіе®ҡеҪ“еүҚеё§жҳҜеҗҰжңүжңүж•Ҳжҗ“жӢӣпјҲtolerance +1 иЎҘеҒҝйҖҡдҝЎе»¶иҝҹпјү
        var tolerance:Number = InputCommandRuntimeConfigLoader.bufferTolerance + 1;
        var active:Boolean = false;

        if (жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІID != 0 &&
            !жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІе·Іж¶Ҳиҙ№ &&
            frame - жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІеё§ <= tolerance) {
            active = true;
        }

        if (active) {
            жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣID = жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІID;
            жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣеҗҚ = жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІеҗҚ;
        } else {
            жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣID = 0;
            жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣеҗҚ = "";
            if (жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІID != 0 && frame - жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІеё§ > tolerance) {
                жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІID = 0;
            }
        }

        // жҗ“жӢӣиҜҶеҲ«ж—Ҙеҝ—е·ІиҝҒз§»еҲ° WebView2 combo overlayпјҢй»ҳи®ӨдёҚеҲ·еұҸ
        // еҰӮйңҖи°ғиҜ•еҸҜеҸ–ж¶ҲжіЁйҮҠ:
        // if(жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣеҗҚ !== "" && frame == жҺ§еҲ¶еҜ№иұЎ.жҗ“жӢӣзј“еҶІеё§){
        //     _root.еҸ‘еёғж¶ҲжҒҜ(_root.её§и®Ўж—¶еҷЁ.еҪ“еүҚеё§ж•° + ":жЁЎз»„=" + жЁЎз»„еҗҚ + " жҗ“жӢӣ=" + жҺ§еҲ¶еҜ№иұЎ.еҪ“еүҚжҗ“жӢӣеҗҚ + " [Launcher DFA]");
        // }
    }
};




