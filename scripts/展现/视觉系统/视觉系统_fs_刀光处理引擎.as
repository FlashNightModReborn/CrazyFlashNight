/* 
   刀光系统
   本系统通过存储最近多帧的刀口点集，生成连续带状拖尾效果，
   实现从刀尖一路延伸的渐隐效果，而不仅仅是两帧间的连接面。
*/

_root.刀光系统 = {};

_root.刀光系统.初始化 = function () {
    // 定义各种刀光样式
    this.刀光样式 = {
        预设: {
            颜色: 0xFFFFFF,
            线条颜色: 0xFFFFFF,
            线条宽度: 2,
            填充透明度: 100,
            线条透明度: 100
        },
        白色蓝框: {
            颜色: 0xFFFFFF,
            线条颜色: 0x4FB6FF,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        红色透明: {
            颜色: 0xFF6666,
            线条颜色: 0xFF6666,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        蓝色魅影: {
            颜色: 0x4DE6FF,
            线条颜色: 0x4FB6FF,
            线条宽度: 2,
            填充透明度: 50,
            线条透明度: 50
        },
        蓝色幽灵: {
            颜色: 0x74EBFF,
            线条颜色: 0x74EBFF,
            线条宽度: 2,
            填充透明度: 25,
            线条透明度: 25
        }
    };

    // 存储每个发射者（例如每个挥刀动画）的最近多帧刀口点集队列
    this.绘制记录 = {};
    this.最大帧数 = 5; // 可调整，代表存储最近5帧数据
};

_root.刀光系统.初始化();

//
// 以下为对外接口函数，可根据需要调用
//

// 绘制刀本体及其拖尾刀光（例如角色挥刀时）
_root.刀光系统.绘制刀及其刀光 = function(影片剪辑:MovieClip, 刀光样式名:String, 参数:Object) {
    _root.残影系统.绘制元件(影片剪辑.man.刀, 参数);
    this.绑定并绘制刀光(影片剪辑, 刀光样式名);
};

// 绘制人物整体及其拖尾刀光（例如人物动作整体拖尾）
_root.刀光系统.绘制人物及其刀光 = function(影片剪辑:MovieClip, 刀光样式名:String, 参数:Object) {
    _root.残影系统.绘制元件(影片剪辑, 参数);
    this.绑定并绘制刀光(影片剪辑, 刀光样式名);
};

//
// 绑定刀光并进行绘制：采集刀口位置数据并传递给核心绘制函数
//
_root.刀光系统.绑定并绘制刀光 = function(影片剪辑:MovieClip, 刀光样式名:String) {
    var 刀口集合 = [];
    var 游戏世界 = _root.gameworld;
    // 假设刀的装扮中包含多个刀口位置（如刀尖、刀尾等）
    var 装扮 = 影片剪辑.man.刀.刀.装扮;
    for (var i = 1; i <= 5; i++) {
        var 当前刀口 = 装扮["刀口位置" + i];
        if (当前刀口 && 当前刀口._x != undefined) {
            // 将局部坐标转换为全局坐标，再转换为游戏世界坐标
            var myPoint = {x: 当前刀口._x, y: 当前刀口._y};
            装扮.localToGlobal(myPoint);
            游戏世界.globalToLocal(myPoint);
            刀口集合.push(当前刀口);
        }
    }
    if (刀口集合.length > 0) {
        // 以影片剪辑名称作为发射者标识，确保唯一性
        this.绘制刀光(影片剪辑._name, 刀口集合, 刀光样式名);
    }
};

//
// 当刀作为独立对象引用时使用
//
_root.刀光系统.刀引用绘制刀光 = function(自机:MovieClip, 影片剪辑:MovieClip, 刀光样式名:String) {
    var 刀口集合 = [];
    var 游戏世界 = _root.gameworld;
    for (var i = 1; i <= 5; i++) {
        var 当前刀口 = 影片剪辑["刀口位置" + i];
        if (当前刀口 && 当前刀口._x != undefined) {
            var myPoint = {x: 当前刀口._x, y: 当前刀口._y};
            影片剪辑.localToGlobal(myPoint);
            游戏世界.globalToLocal(myPoint);
            刀口集合.push(当前刀口);
        }
    }
    if (刀口集合.length > 0) {
        this.绘制刀光(自机, 刀口集合, 刀光样式名);
    }
};

//
// 核心绘制函数：存储当前帧的点集，并根据多帧队列绘制拖尾
//
_root.刀光系统.绘制刀光 = function(发射者, 刀口集合, 刀光样式名) {
    var 当前帧 = _root.帧计时器.当前帧数;
    var 当前点集数组 = [];
    // 将每个刀口位置转换为游戏世界中的点集（例如返回包含刀尖与刀尾的两个点）
    for (var i = 0; i < 刀口集合.length; i++) {
        var 点集 = _root.影片剪辑至游戏世界点集(刀口集合[i]);
        当前点集数组.push(点集);
    }

    // 如果发射者尚无记录，则初始化数据队列
    if (!this.绘制记录[发射者]) {
        this.绘制记录[发射者] = {
            点集队列: [当前点集数组],
            最后绘制帧: 当前帧
        };
        return;
    }

    var 记录 = this.绘制记录[发射者];
    // 将当前帧的点集加入队列
    记录.点集队列.push(当前点集数组);
    // 保持队列长度不超过最大帧数
    if (记录.点集队列.length > this.最大帧数) {
        记录.点集队列.shift();
    }

    var 队列长度 = 记录.点集队列.length;
    // 对队列中相邻帧的数据依次连接，形成连续拖尾效果
    for (var j = 0; j < 队列长度 - 1; j++) {
        var 旧点集数组 = 记录.点集队列[j];
        var 新点集数组 = 记录.点集队列[j + 1];
        // 若两帧采样的刀口数量不一致，则跳过该段
        if (旧点集数组.length != 新点集数组.length) {
            continue;
        }
        // 针对每个刀口位置连接成四边形
        for (var k = 0; k < 旧点集数组.length; k++) {
            var 临时点集 = this.连接刀口点集(旧点集数组[k], 新点集数组[k]);
            // 计算透明度：队列中越旧的段透明度越低
            // 这里j=0表示最旧段，j=队列长度-2表示最新段（你可根据需求调整渐变范围）
            var 透明度 = 100 - (j / (队列长度 - 1)) * 50; // 从100%渐变到50%
            this.绘制于残影系统(临时点集, 刀光样式名, 透明度);
        }
    }
    记录.最后绘制帧 = 当前帧;
};

//
// 根据样式和透明度绘制到残影系统
//
_root.刀光系统.绘制于残影系统 = function(刀口点集, 刀光样式名, 透明度) {
    var 样式 = this.刀光样式[刀光样式名] || this.刀光样式['预设'];
    // 根据传入透明度计算最终填充和线条的透明度
    var 最终填充透明度 = 样式.填充透明度 * (透明度 / 100);
    var 最终线条透明度 = 样式.线条透明度 * (透明度 / 100);
    _root.残影系统.绘制形状(刀口点集, 样式.颜色, 样式.线条颜色, 样式.线条宽度, 最终填充透明度, 最终线条透明度);
};

//
// 连接两帧相同刀口位置的点集，形成四边形（假设每个点集包含两个点：刀尖与刀尾）
// 顺序为：旧帧刀尖、旧帧刀尾、新帧刀尾、新帧刀尖
//
_root.刀光系统.连接刀口点集 = function(旧点集, 新点集) {
    if (!旧点集 || !新点集 || 旧点集.length < 2 || 新点集.length < 2) {
        return [];
    }
    var 连接后点集 = [旧点集[0], 旧点集[1], 新点集[1], 新点集[0]];
    return 连接后点集;
};
