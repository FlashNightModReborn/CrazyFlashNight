// v8-D1: 实体批量更新微工作负载
var _entities:Array = [];
var _px:Array = []; var _py:Array = []; var _vx:Array = []; var _vy:Array = [];
var _mi:Number;
for (_mi = 0; _mi < 100; _mi++) {
    _entities[_mi] = {x:_mi, y:_mi, vx:1, vy:0.5};
    _px[_mi] = _mi; _py[_mi] = _mi; _vx[_mi] = 1; _vy[_mi] = 0.5;
}

function bench_micro_entity_aos():Number {
    var t0:Number = getTimer();
    var j:Number = 200;
    var e:Object;
    while (j--) {
        var i:Number = 100;
        while (i--) {
            e = _entities[i];
            e.x += e.vx; e.y += e.vy;
        }
    }
    _bh += _entities[0].x;
    return getTimer() - t0;
}

function bench_micro_entity_soa():Number {
    var t0:Number = getTimer();
    var j:Number = 200;
    while (j--) {
        var i:Number = 100;
        while (i--) {
            _px[i] += _vx[i]; _py[i] += _vy[i];
        }
    }
    _bh += _px[0];
    return getTimer() - t0;
}

// v8-D2: 脏标记优化微工作负载
function bench_micro_set_always():Number {
