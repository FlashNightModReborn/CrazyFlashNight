                <script><![CDATA[function 上一页()
{
	if (shopCartContent._y <= -mask2._height)
	{
		shopCartContent._y += mask2._height;
	}
	获得页数();
}
function 下一页()
{
	if (shopCartContent._y > -(shopCartContent._height - mask2._height))
	{
		shopCartContent._y -= mask2._height;
	}
	获得页数();
}
function 获得页数()
{
	总页数 = Math.floor(shopCartContent._height / mask2._height) + 1;
	当前页数 = Math.floor((-shopCartContent._y) / mask2._height) + 1;
	if (当前页数 == 1)
	{
		上一页按钮._visible = 0;
	}
	else
	{
		上一页按钮._visible = 1;
	}
	if (当前页数 == 总页数)
	{
		下一页按钮._visible = 0;
	}
	else
	{
		下一页按钮._visible = 1;
	}
}
active = false;
